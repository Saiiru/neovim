#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
source "$SCRIPT_DIR/common.sh"

wifi_enabled() {
  command -v nmcli >/dev/null 2>&1 || return 1
  [[ "$(nmcli radio wifi 2>/dev/null | tr '[:upper:]' '[:lower:]')" == "enabled" ]]
}

bluetooth_enabled() {
  command -v bluetoothctl >/dev/null 2>&1 || return 1
  bluetoothctl show 2>/dev/null | grep -q "Powered: yes"
}

idle_enabled() {
  [[ -f "${XDG_CACHE_HOME:-$HOME/.cache}/noir-shell/idle-inhibit.pid" ]]
}

night_light_enabled() {
  pgrep -x wlsunset >/dev/null 2>&1
}

toggle_wifi() {
  command -v nmcli >/dev/null 2>&1 || {
    notify_missing "networkmanager" "device actions"
    exit 1
  }

  if wifi_enabled; then
    exec nmcli radio wifi off
  else
    exec nmcli radio wifi on
  fi
}

toggle_bluetooth() {
  if ! command -v bluetoothctl >/dev/null 2>&1; then
    notify_missing "bluez" "device actions"
    exit 1
  fi

  if bluetooth_enabled; then
    exec bluetoothctl power off
  fi

  exec bluetoothctl power on
}

toggle_idle() {
  exec bin/niri/actions" idle-toggle
}

toggle_night_light() {
  command -v wlsunset >/dev/null 2>&1 || {
    notify_missing "wlsunset" "device actions"
    exit 1
  }

  if night_light_enabled; then
    exec pkill -x wlsunset
  fi

  args=(
    -T "${WLSUNSET_DAY_TEMP:-6500}"
    -t "${WLSUNSET_NIGHT_TEMP:-3800}"
    -d "${WLSUNSET_DURATION:-1800}"
  )

  if [[ -n "${WLSUNSET_LAT:-}" && -n "${WLSUNSET_LON:-}" ]]; then
    args+=(-l "$WLSUNSET_LAT" -L "$WLSUNSET_LON")
  else
    args+=(-S "${WLSUNSET_SUNRISE:-06:30}" -s "${WLSUNSET_SUNSET:-18:30}")
  fi

  nohup wlsunset "${args[@]}" >/dev/null 2>&1 &
}

keyboard_status() {
  timeout 2 niri msg -j keyboard-layouts 2>/dev/null | jq -r '.names[.current_idx] // "unknown"'
}

status_json() {
  local wifi_state bt_state kb_state idle_state night_state

  wifi_state="off"
  bt_state="off"
  kb_state="$(keyboard_status 2>/dev/null || printf 'unknown')"
  idle_state="off"
  night_state="off"

  wifi_enabled && wifi_state="on"
  bluetooth_enabled && bt_state="on"
  idle_enabled && idle_state="on"
  night_light_enabled && night_state="on"

  jq -n \
    --arg wifi "$wifi_state" \
    --arg bluetooth "$bt_state" \
    --arg keyboard "$kb_state" \
    --arg idle "$idle_state" \
    --arg nightlight "$night_state" \
    '{wifi:$wifi, bluetooth:$bluetooth, keyboard:$keyboard, idle:$idle, nightlight:$nightlight}'
}

case "${1:-menu}" in
  audio-settings)
    command -v pavucontrol >/dev/null 2>&1 || { notify_missing "pavucontrol" "device actions"; exit 1; }
    exec pavucontrol
    ;;
  network-tui)
    exec bin/session/system-actions" nmtui
    ;;
  wifi-toggle)
    toggle_wifi
    ;;
  bluetooth-toggle)
    toggle_bluetooth
    ;;
  keyboard-next)
    exec niri msg action switch-layout next
    ;;
  idle-toggle)
    toggle_idle
    ;;
  night-light-toggle)
    toggle_night_light
    ;;
  status)
    status_json
    ;;
  menu)
    action="$(
      printf '%s\n' \
        'Audio settings' \
        'Network TUI' \
        'Toggle Wi-Fi' \
        'Toggle Bluetooth' \
        'Next keyboard layout' \
        'Toggle idle inhibitor' \
        'Toggle night light' \
      | pick_action 'devices> '
    )"

    case "${action:-}" in
      'Audio settings') exec "$0" audio-settings ;;
      'Network TUI') exec "$0" network-tui ;;
      'Toggle Wi-Fi') exec "$0" wifi-toggle ;;
      'Toggle Bluetooth') exec "$0" bluetooth-toggle ;;
      'Next keyboard layout') exec "$0" keyboard-next ;;
      'Toggle idle inhibitor') exec "$0" idle-toggle ;;
      'Toggle night light') exec "$0" night-light-toggle ;;
      *) exit 0 ;;
    esac
    ;;
  *)
    printf 'usage: %s [menu|audio-settings|network-tui|wifi-toggle|bluetooth-toggle|keyboard-next|idle-toggle|night-light-toggle|status]\n' "$0" >&2
    exit 1
    ;;
esac
