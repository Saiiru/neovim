#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
source "$SCRIPT_DIR/common.sh"

show_overlay() {
  exec niri msg action show-hotkey-overlay
}

toggle_launcher() {
  exec bash -lc 'if command -v kora-launcher >/dev/null 2>&1; then exec kora-launcher; else exec fuzzel; fi'
}

toggle_notifications() {
  if command -v makoctl >/dev/null 2>&1; then
    exec makoctl dismiss --all
  fi

  notify_info "notifications" "No notification center is configured"
}

case "${1:-menu}" in
  overlay)
    show_overlay
    ;;
  launcher)
    toggle_launcher
    ;;
  notifications)
    toggle_notifications
    ;;
  session)
    exec kora-session picker
    ;;
  menu)
    action="$(
      printf '%s\n' \
        'Show hotkey overlay' \
        'Toggle launcher' \
        'Toggle notifications' \
        'Open session picker' \
      | pick_action 'hints> '
    )"

    case "${action:-}" in
      'Show hotkey overlay') exec "$0" overlay ;;
      'Toggle launcher') exec "$0" launcher ;;
      'Toggle notifications') exec "$0" notifications ;;
      'Open session picker') exec "$0" session ;;
      *) exit 0 ;;
    esac
    ;;
  *)
    printf 'usage: %s [menu|overlay|launcher|notifications|session]\n' "$0" >&2
    exit 1
    ;;
esac
