#!/usr/bin/env bash
set -euo pipefail

IDF_EXPORT="${IDF_EXPORT:-$HOME/esp/esp-idf/export.sh}"

if [[ -f "$IDF_EXPORT" ]]; then
  # shellcheck disable=SC1090
  source "$IDF_EXPORT"
else
  echo "ESP-IDF not found: $IDF_EXPORT" >&2
  exit 2
fi

case "${1:-help}" in
  build)
    idf.py build
    ;;
  flash)
    idf.py -p "${ESPPORT:-/dev/ttyUSB0}" flash
    ;;
  monitor)
    idf.py -p "${ESPPORT:-/dev/ttyUSB0}" monitor
    ;;
  fm)
    idf.py -p "${ESPPORT:-/dev/ttyUSB0}" flash monitor
    ;;
  menu)
    idf.py menuconfig
    ;;
  clean)
    idf.py fullclean
    ;;
  *)
    cat <<'EOF'
esp build      build firmware
esp flash      flash firmware
esp monitor    serial monitor
esp fm         flash + monitor
esp menu       menuconfig
esp clean      fullclean

Env:
  ESPPORT=/dev/ttyUSB0
  IDF_EXPORT=$HOME/esp/esp-idf/export.sh
EOF
    ;;
esac
