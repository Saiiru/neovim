#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
source "$SCRIPT_DIR/common.sh"

case "${1:-menu}" in
  lock)
    exec loginctl lock-session
    ;;
  logout)
    exec niri msg action quit
    ;;
  reboot)
    exec systemctl reboot
    ;;
  shutdown)
    exec systemctl poweroff
    ;;
  suspend)
    exec systemctl suspend
    ;;
  menu)
    action="$(
      printf '%s\n' \
        'Lock' \
        'Logout' \
        'Suspend' \
        'Reboot' \
        'Shutdown' \
      | pick_action 'power> '
    )"

    case "${action:-}" in
      Lock) exec "$0" lock ;;
      Logout) exec "$0" logout ;;
      Suspend) exec "$0" suspend ;;
      Reboot) exec "$0" reboot ;;
      Shutdown) exec "$0" shutdown ;;
      *) exit 0 ;;
    esac
    ;;
  *)
    printf 'usage: %s [menu|lock|logout|suspend|reboot|shutdown]\n' "$0" >&2
    exit 1
    ;;
esac
