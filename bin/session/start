#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
source "$SCRIPT_DIR/common.sh"

open_picker() {
  command -v sesh >/dev/null 2>&1 || {
    notify_missing "sesh" "session actions"
    exit 1
  }
  exec sesh picker -i -c -t -z
}

open_in_kitty() {
  local title="$1"
  local command="$2"
  open_kitty_tool "$title" "$command" "float_session_tool"
}

case "${1:-picker}" in
  --inline|inline)
    open_picker
    ;;
  picker)
    open_in_kitty "Session Picker" "sesh picker -i -c -t -z"
    ;;
  last)
    open_in_kitty "Last Session" "sesh last"
    ;;
  root)
    open_in_kitty "Session Root" "printf \"%s\n\" \"$(sesh root 2>/dev/null || pwd)\"; printf \"\nPress enter to close...\"; read"
    ;;
  *)
    printf 'usage: %s [picker|last|root|--inline]\n' "$0" >&2
    exit 1
    ;;
esac
