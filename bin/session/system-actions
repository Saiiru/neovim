#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
source "$SCRIPT_DIR/common.sh"

tmux_popup_actions="$HOME/.config/tmux/scripts/tmux-popup-actions.sh"
tmux_session_actions="$HOME/.config/tmux/scripts/tmux-session-actions.sh"

open_files() {
  if command -v pcmanfm >/dev/null 2>&1; then
    exec pcmanfm
  elif command -v dolphin >/dev/null 2>&1; then
    exec dolphin
  elif command -v vifm >/dev/null 2>&1; then
    open_kitty_tool "Files" "vifm"
  else
    exec xdg-open "$HOME"
  fi
}

open_browser() {
  exec xdg-open "${BROWSER_START_PAGE:-https://start.duckduckgo.com}"
}

open_terminal() {
  local use_tmux=true
  if [[ "${1:-}" == "--no-tmux" ]]; then
    use_tmux=false
  fi

  local cmd=""
  if [[ "$use_tmux" == "true" ]]; then
    cmd="tmux"
  fi

  if command -v kitty >/dev/null 2>&1; then
    if [[ -n "$cmd" ]]; then
      exec kitty "$cmd"
    else
      exec kitty
    fi
  elif command -v ghostty >/dev/null 2>&1; then
    if [[ -n "$cmd" ]]; then
      exec ghostty -e "$cmd"
    else
      exec ghostty
    fi
  else
    if [[ -n "$cmd" ]]; then
      exec xterm -e "$cmd"
    else
      exec xterm
    fi
  fi
}

case "${1:-menu}" in
  terminal)
    shift || true
    open_terminal "$@"
    ;;
  files)
    open_files
    ;;
  browser)
    open_browser
    ;;
  yazi)
    exec "$tmux_popup_actions" yazi
    ;;
  lazygit)
    exec "$tmux_popup_actions" lazygit
    ;;
  btop)
    exec "$tmux_popup_actions" btop
    ;;
  nvtop)
    command -v nvtop >/dev/null 2>&1 || { notify_missing "nvtop"; exit 1; }
    open_kitty_tool "NVTop" "nvtop" "float_system_tool"
    ;;
  nmtui)
    command -v nmtui >/dev/null 2>&1 || { notify_missing "nmtui"; exit 1; }
    open_kitty_tool "Network TUI" "nmtui" "float_system_tool"
    ;;
  vifm)
    command -v vifm >/dev/null 2>&1 || { notify_missing "vifm"; exit 1; }
    open_kitty_tool "Vifm" "vifm" "float_system_tool"
    ;;
  mail)
    command -v neomutt >/dev/null 2>&1 || { notify_missing "neomutt"; exit 1; }
    open_kitty_tool "Neomutt" "neomutt" "float_system_tool"
    ;;
  calendar)
    command -v calcure >/dev/null 2>&1 || { notify_missing "calcure"; exit 1; }
    open_kitty_tool "Calcure" "calcure" "float_system_tool"
    ;;
  sesh)
    exec "$tmux_session_actions" picker
    ;;
  hints)
    exec bin/niri/actions" hotkeys
    ;;
  menu)
    action="$(
      printf '%s\n' \
        'Terminal' \
        'Files' \
        'Browser' \
        'Sesh' \
        'Yazi' \
        'Lazygit' \
        'Btop' \
        'NVTop' \
        'Network TUI' \
        'Vifm' \
        'Mail' \
        'Calendar' \
        'Hints' \
      | pick_action 'system> '
    )"

    case "${action:-}" in
      Terminal) exec "$0" terminal ;;
      Files) exec "$0" files ;;
      Browser) exec "$0" browser ;;
      Sesh) exec "$0" sesh ;;
      Yazi) exec "$0" yazi ;;
      Lazygit) exec "$0" lazygit ;;
      Btop) exec "$0" btop ;;
      NVTop) exec "$0" nvtop ;;
      'Network TUI') exec "$0" nmtui ;;
      Vifm) exec "$0" vifm ;;
      Mail) exec "$0" mail ;;
      Calendar) exec "$0" calendar ;;
      Hints) exec "$0" hints ;;
      *) exit 0 ;;
    esac
    ;;
  *)
    printf 'usage: %s [menu|terminal|files|browser|sesh|yazi|lazygit|btop|nvtop|nmtui|vifm|mail|calendar|hints]\n' "$0" >&2
    exit 1
    ;;
esac
