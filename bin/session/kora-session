#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

if [[ -x "$REPO_ROOT/bin/session/start" ]]; then
  exec "$REPO_ROOT/bin/session/start" "${@:-picker}"
fi

if command -v start >/dev/null 2>&1; then
  exec start "${@:-picker}"
fi

echo "kora-session: bin/session/start not found" >&2
exit 1
