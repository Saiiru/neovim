#!/usr/bin/env bash
# Dotfiles Architecture Scanner (KORA-03)
# Scans the repository and classifies files into ACTIVE, REFERENCE, LEGACY, UNKNOWN.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
cd "$REPO_ROOT"

# Classification patterns
ACTIVE_DIRS=(
    "config/nvim"
    "config/zsh"
    "config/tmux"
    "config/kitty"
    "config/starship"
    "config/mise"
    "config/niri"
    "bin/"
    "install/"
    "docs/"
    "assets/"
)

LEGACY_DIRS=()

REFERENCE_DIRS=(
    "docs/credits"
    "docs/references"
)

echo "--- Dotfiles Architecture Scan Report ---"
echo "Root: $REPO_ROOT"
echo ""

classify() {
    local path="$1"
    
    for d in "${ACTIVE_DIRS[@]}"; do
        [[ "$path" == "$d"* ]] && echo "ACTIVE" && return
    done
    
    for d in "${LEGACY_DIRS[@]}"; do
        [[ "$path" == "$d"* ]] && echo "LEGACY" && return
    done
    
    for d in "${REFERENCE_DIRS[@]}"; do
        [[ "$path" == "$d"* ]] && echo "REFERENCE" && return
    done
    
    echo "UNKNOWN"
}

# Scan config
find config -maxdepth 1 -not -path '*/.*' | while read -r line; do
    path="${line#./}"
    status=$(classify "$path")
    printf "[%-10s] %s\n" "$status" "$path"
done

# Scan bin
find bin -maxdepth 1 -not -path '*/.*' | while read -r line; do
    path="${line#./}"
    status=$(classify "$path")
    printf "[%-10s] %s\n" "$status" "$path"
done

# Scan install
find install -maxdepth 1 -not -path '*/.*' | while read -r line; do
    path="${line#./}"
    status=$(classify "$path")
    printf "[%-10s] %s\n" "$status" "$path"
done
