#!/usr/bin/env bash
set -euo pipefail

python3 - <<'PY'
import json
import os
import pathlib
import subprocess
import time


def read_cpu():
    def snap():
        with open("/proc/stat", "r", encoding="utf-8") as fh:
            parts = fh.readline().split()[1:]
        values = list(map(int, parts))
        idle = values[3] + values[4]
        total = sum(values)
        return idle, total

    idle1, total1 = snap()
    time.sleep(0.08)
    idle2, total2 = snap()
    totald = max(total2 - total1, 1)
    idled = idle2 - idle1
    return round((1.0 - idled / totald) * 100, 1)


def read_mem():
    values = {}
    with open("/proc/meminfo", "r", encoding="utf-8") as fh:
        for line in fh:
            key, value = line.split(":", 1)
            values[key] = int(value.strip().split()[0])
    total = values.get("MemTotal", 1) / 1024 / 1024
    available = values.get("MemAvailable", 0) / 1024 / 1024
    used = max(total - available, 0)
    pct = round((used / total) * 100, 1)
    return pct, f"{used:.1f}G", f"{total:.1f}G"


def read_temp():
    for zone in pathlib.Path("/sys/class/thermal").glob("thermal_zone*/temp"):
        try:
            raw = int(zone.read_text(encoding="utf-8").strip())
        except Exception:
            continue
        if 1000 <= raw <= 120000:
            return round(raw / 1000.0, 1)
    return 0.0


def read_brightness():
    try:
        current = int(subprocess.check_output(["brightnessctl", "g"], text=True).strip())
        maximum = int(subprocess.check_output(["brightnessctl", "m"], text=True).strip())
        if maximum > 0:
            return round((current / maximum) * 100, 1)
    except Exception:
        pass
    return 0.0


def process_running(name):
    return subprocess.run(["pgrep", "-x", name], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode == 0


cache_dir = pathlib.Path.home() / ".cache" / "noir-shell"
pid_file = cache_dir / "idle-inhibit.pid"
idle_inhibited = False
if pid_file.exists():
    try:
        pid = int(pid_file.read_text(encoding="utf-8").strip())
        os.kill(pid, 0)
        idle_inhibited = True
    except Exception:
        idle_inhibited = False

data = {
    "cpu": read_cpu(),
    "memoryPercent": read_mem()[0],
    "memoryUsed": read_mem()[1],
    "memoryTotal": read_mem()[2],
    "temperature": read_temp(),
    "brightness": read_brightness(),
    "nightLight": process_running("wlsunset"),
    "idleInhibited": idle_inhibited,
}

print(json.dumps(data))
PY
