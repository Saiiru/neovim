#!/usr/bin/env bash
set -euo pipefail

required_commands=(
  niri
  kitty
  firefox
  pipewire
  wireplumber
  wpctl
  grim
  slurp
  wl-copy
  systemctl
)

recommended_commands=(
  fastfetch
  inxi
  sensors
  pactl
  nwg-look
  brightnessctl
)

required_paths=(
  "$HOME/.config/niri/config.kdl"
)

status=0

check_command_group() {
  local label="$1"
  shift

  printf '## %s\n' "$label"
  for command_name in "$@"; do
    if command -v "$command_name" >/dev/null 2>&1; then
      printf 'ok      %s -> %s\n' "$command_name" "$(command -v "$command_name")"
    else
      printf 'missing %s\n' "$command_name"
      [[ "$label" == "Required commands" ]] && status=1
    fi
  done
  printf '\n'
}

check_paths() {
  printf '## Required paths\n'
  for path in "${required_paths[@]}"; do
    if [[ -e "$path" || -L "$path" ]]; then
      printf 'ok      %s\n' "$path"
    else
      printf 'missing %s\n' "$path"
      status=1
    fi
  done
  printf '\n'
}

check_niri_config() {
  printf '## Niri validation\n'
  if ! command -v niri >/dev/null 2>&1; then
    printf 'skip    niri not found\n\n'
    return
  fi

  if niri validate -c "$HOME/.config/niri/config.kdl" >/dev/null 2>&1; then
    printf 'ok      niri config validates\n'
  else
    printf 'failed  niri config validation\n'
    status=1
  fi
  printf '\n'
}

check_systemd_user() {
  printf '## User services\n'
  if ! command -v systemctl >/dev/null 2>&1; then
    printf 'skip    systemctl not found\n\n'
    return
  fi

  for unit in pipewire.socket pipewire-pulse.socket wireplumber.service; do
    local state
    state="$(systemctl --user is-enabled "$unit" 2>/dev/null || true)"
    printf '%-7s %s\n' "${state:-unknown}" "$unit"
  done
  printf '\n'
}

check_command_group "Required commands" "${required_commands[@]}"
check_command_group "Recommended commands" "${recommended_commands[@]}"
check_paths
check_niri_config
check_systemd_user

if [[ "$status" == "0" ]]; then
  printf 'Arcane stack check passed.\n'
else
  printf 'Arcane stack check found missing required items.\n'
fi

exit "$status"
