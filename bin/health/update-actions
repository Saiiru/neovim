#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
source "$SCRIPT_DIR/common.sh"

update_count() {
  if command -v checkupdates >/dev/null 2>&1; then
    checkupdates 2>/dev/null | wc -l
  else
    printf '0\n'
  fi
}

run_update_terminal() {
  open_kitty_tool "System Update" "sudo pacman -Syu || true; if command -v flatpak >/dev/null 2>&1; then echo; flatpak update -y || true; fi; printf '\nPress enter to close...'; read"
}

run_dotfiles_pull() {
  open_kitty_tool "Dotfiles" "cd \"$repo_root\" && git status --short && echo && git pull --ff-only || true; printf '\nPress enter to close...'; read"
}

case "${1:-menu}" in
  count)
    update_count
    ;;
  upgrade)
    run_update_terminal
    ;;
  dotfiles)
    run_dotfiles_pull
    ;;
  menu)
    action="$(
      printf '%s\n' \
        "System Update ($(update_count))" \
        'Dotfiles Pull' \
      | pick_action 'update> '
    )"

    case "${action:-}" in
      System\ Update*) exec "$0" upgrade ;;
      'Dotfiles Pull') exec "$0" dotfiles ;;
      *) exit 0 ;;
    esac
    ;;
  *)
    printf 'usage: %s [menu|count|upgrade|dotfiles]\n' "$0" >&2
    exit 1
    ;;
esac
