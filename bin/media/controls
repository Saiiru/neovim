#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
source "$SCRIPT_DIR/common.sh"

require_playerctl() {
  command -v playerctl >/dev/null 2>&1 || {
    notify_missing "playerctl" "media actions"
    exit 1
  }
}

player_status() {
  require_playerctl

  if ! playerctl status >/dev/null 2>&1; then
    printf 'No active player\n'
    return 0
  fi

  local status title artist
  status="$(playerctl status 2>/dev/null || true)"
  title="$(playerctl metadata title 2>/dev/null || true)"
  artist="$(playerctl metadata artist 2>/dev/null || true)"

  if [[ -n "$artist" && -n "$title" ]]; then
    printf '%s: %s — %s\n' "$status" "$artist" "$title"
  elif [[ -n "$title" ]]; then
    printf '%s: %s\n' "$status" "$title"
  else
    printf '%s\n' "$status"
  fi
}

case "${1:-menu}" in
  toggle)
    require_playerctl
    exec playerctl play-pause
    ;;
  next)
    require_playerctl
    exec playerctl next
    ;;
  previous)
    require_playerctl
    exec playerctl previous
    ;;
  stop)
    require_playerctl
    exec playerctl stop
    ;;
  status)
    player_status
    ;;
  menu)
    action="$(
      printf '%s\n' \
        'Play/Pause' \
        'Previous' \
        'Next' \
        'Stop' \
        'Show status' \
      | pick_action 'media> '
    )"

    case "${action:-}" in
      'Play/Pause') exec "$0" toggle ;;
      Previous) exec "$0" previous ;;
      Next) exec "$0" next ;;
      Stop) exec "$0" stop ;;
      'Show status')
        status="$(player_status)"
        [[ -n "${status:-}" ]] && notify_info "media actions" "$status"
        ;;
      *) exit 0 ;;
    esac
    ;;
  *)
    printf 'usage: %s [menu|toggle|next|previous|stop|status]\n' "$0" >&2
    exit 1
    ;;
esac
