#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"

library_dir="${DOTFILES_WALLPAPER_DIR:-${XDG_PICTURES_DIR:-$HOME/Pictures}/Wallpapers}"
fallback_dir="${DOTFILES_REPO:-$HOME/dotfiles}/wallpapers"
state_dir="${XDG_CACHE_HOME:-$HOME/.cache}/dotfiles/wallpaper"
state_file="$state_dir/current"

notify_info() {
  local title="$1"
  local body="$2"
  if command -v notify-send >/dev/null 2>&1; then
    notify-send "$title" "$body" || true
  fi
}

pick_action() {
  local prompt="${1:-wallpaper> }"
  if command -v fuzzel >/dev/null 2>&1; then
    fuzzel --dmenu --prompt "$prompt"
  elif command -v fzf >/dev/null 2>&1; then
    fzf --prompt "$prompt"
  else
    cat
  fi
}

resolve_target() {
  local input="$1"

  if [[ -z "$input" ]]; then
    return 1
  fi

  if [[ -f "$input" ]]; then
    printf '%s\n' "$(realpath "$input")"
    return 0
  fi

  if [[ -f "$library_dir/$input" ]]; then
    printf '%s\n' "$(realpath "$library_dir/$input")"
    return 0
  fi

  return 1
}

write_current() {
  local target="$1"
  mkdir -p "$state_dir"
  printf '%s\n' "$target" > "$state_file"

  if command -v swww >/dev/null 2>&1; then
    swww img "$target" || true
  elif command -v awww >/dev/null 2>&1; then
    awww img "$target" || true
  fi

  notify_info "wallpaper" "$(basename "$target")"
}

pick_random() {
  local source_dir="$library_dir"
  if [[ ! -d "$source_dir" || -z "$(find "$source_dir" -maxdepth 1 -type f 2>/dev/null | head -n 1)" ]]; then
    source_dir="$fallback_dir"
  fi

  if [[ ! -d "$source_dir" ]]; then
    return 0
  fi

  find "$source_dir" -maxdepth 1 -type f \
    \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.webp' \) | shuf -n 1
}

list_candidates() {
  local d
  for d in "$library_dir" "$fallback_dir"; do
    [[ -d "$d" ]] || continue
    find "$d" -maxdepth 1 -type f \
      \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.webp' \)
  done | awk '!seen[$0]++'
}

show_menu() {
  local choice
  choice="$(
    list_candidates | sort | pick_action 'wallpaper> '
  )"

  [[ -n "$choice" ]] || exit 0
  local target
  target="$(resolve_target "$choice")"
  write_current "$target"
}

case "${1:-menu}" in
  menu)
    show_menu
    ;;
  random)
    target="$(pick_random)"
    [[ -n "${target:-}" ]] || exit 1
    write_current "$(realpath "$target")"
    ;;
  init)
    if command -v swww-daemon >/dev/null 2>&1; then
      pgrep -x swww-daemon >/dev/null 2>&1 || swww-daemon >/dev/null 2>&1 &
    elif command -v awww-daemon >/dev/null 2>&1; then
      pgrep -x awww-daemon >/dev/null 2>&1 || awww-daemon >/dev/null 2>&1 &
    fi

    current="$(cat "$state_file" 2>/dev/null || true)"
    if [[ -n "$current" && -f "$current" ]]; then
      write_current "$current"
    else
      target="$(pick_random)"
      if [[ -n "${target:-}" ]]; then
        write_current "$(realpath "$target")"
      else
        notify_info "wallpaper" "No wallpapers found in $library_dir"
      fi
    fi
    ;;
  set)
    shift
    target="$(resolve_target "${1:-}")"
    write_current "$target"
    ;;
  current)
    cat "$state_file" 2>/dev/null || true
    ;;
  current-name)
    current="$(cat "$state_file" 2>/dev/null || true)"
    [[ -n "$current" ]] && basename "$current"
    ;;
  open-dir)
    mkdir -p "$library_dir"
    exec xdg-open "$library_dir"
    ;;
  list)
    if [[ -d "$library_dir" ]]; then
      find "$library_dir" -maxdepth 1 -type f | sort
    fi
    if [[ -d "$fallback_dir" && "$fallback_dir" != "$library_dir" ]]; then
      find "$fallback_dir" -maxdepth 1 -type f | sort
    fi
    ;;
  *)
    printf 'usage: %s [init|menu|random|set PATH|current|current-name|open-dir|list]\n' "$0" >&2
    exit 1
    ;;
esac
