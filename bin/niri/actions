#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
source "$SCRIPT_DIR/common.sh"

cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/noir-shell"
idle_pid_file="$cache_dir/idle-inhibit.pid"
mkdir -p "$cache_dir"

toggle_idle() {
  if [[ -f "$idle_pid_file" ]]; then
    pid="$(cat "$idle_pid_file" 2>/dev/null || true)"
    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
      kill "$pid" 2>/dev/null || true
      rm -f "$idle_pid_file"
      notify_info "idle" "Idle inhibitor disabled"
      return
    fi
  fi

  systemd-inhibit --what=idle --why="NoirShell manual idle inhibit" bash -lc 'sleep infinity' >/dev/null 2>&1 &
  echo "$!" > "$idle_pid_file"
  notify_info "idle" "Idle inhibitor enabled"
}

toggle_night_light() {
  if pgrep -x wlsunset >/dev/null 2>&1; then
    pkill -x wlsunset
    notify_info "night light" "Disabled"
  else
    nohup wlsunset -T 4500 -t 6500 >/dev/null 2>&1 &
    notify_info "night light" "Enabled"
  fi
}

case "${1:-overview}" in
  overview)
    exec niri msg action toggle-overview
    ;;
  reload)
    niri msg action load-config-file --path "$HOME/.config/niri/config.kdl" >/dev/null 2>&1 || true
    notify_info "niri" "Config reloaded"
    ;;
  hotkeys)
    exec niri msg action show-hotkey-overlay
    ;;
  screenshot)
    exec niri msg action screenshot
    ;;
  switch-layout)
    exec niri msg action switch-layout next
    ;;
  idle-toggle)
    toggle_idle
    ;;
  night-light-toggle)
    toggle_night_light
    ;;
  *)
    printf 'usage: %s [overview|reload|hotkeys|screenshot|switch-layout|idle-toggle|night-light-toggle]\n' "$0" >&2
    exit 1
    ;;
esac
