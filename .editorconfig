root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.txt]
trim_trailing_whitespace = false

[COMMIT_EDITMSG]
trim_trailing_whitespace = false
max_line_length = 72

[Makefile]
indent_style = tab

[*.go]
indent_style = tab
indent_size = 4
tab_width = 4

[*.py]
indent_size = 4

[*.java]
indent_size = 4

[*.kt]
indent_size = 4

[*.kts]
indent_size = 4

[*.rs]
indent_size = 4

[*.c]
indent_size = 4

[*.h]
indent_size = 4

[*.cpp]
indent_size = 4

[*.hpp]
indent_size = 4

[*.cc]
indent_size = 4

[*.hh]
indent_size = 4

[*.sh]
indent_size = 2

[*.bash]
indent_size = 2

[*.zsh]
indent_size = 2

[*.lua]
indent_size = 2

[*.nix]
indent_size = 2

[*.qml]
indent_size = 2

[*.js]
indent_size = 2

[*.jsx]
indent_size = 2

[*.ts]
indent_size = 2

[*.tsx]
indent_size = 2

[*.vue]
indent_size = 2

[*.svelte]
indent_size = 2

[*.astro]
indent_size = 2

[*.css]
indent_size = 2

[*.scss]
indent_size = 2

[*.less]
indent_size = 2

[*.html]
indent_size = 2

[*.xml]
indent_size = 2

[*.svg]
indent_size = 2

[*.json]
indent_size = 2

[*.jsonc]
indent_size = 2

[*.yml]
indent_size = 2

[*.yaml]
indent_size = 2

[*.toml]
indent_size = 2

[*.kdl]
indent_size = 2

[*.graphql]
indent_size = 2

[*.liquid]
indent_size = 2
