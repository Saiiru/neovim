# Base Git config for this machine.
# Keep repo-wide behavior here; add extra identities with:
#   git config --global include.path ~/.gitconfig.local

[user]
    name = [Saiiru]
    email = sairufsa@gmail.com

[init]
    defaultBranch = main

[core]
    editor = nvim
    excludesfile = ~/.config/git/ignore
    pager = delta

[credential "https://github.com"]
    helper =
    helper = !/usr/bin/gh auth git-credential

[credential "https://gist.github.com"]
    helper =
    helper = !/usr/bin/gh auth git-credential

[merge]
    tool = nvimdiff4
    prompt = false
    conflictstyle = diff3

[mergetool "nvimdiff4"]
    cmd = nvim -d $LOCAL $BASE $REMOTE $MERGED -c 'wincmd w' -c 'wincmd J' -c 'set diffopt&' -c 'set diffopt+=algorithm:patience'
    keepBackup = false

[branch]
    autosetuprebase = always

[push]
    default = current
    autoSetupRemote = true

[pull]
    rebase = false

[diff]
    algorithm = patience
    compactionHeuristic = true
    tool = nvimdiff
    colorMoved = default

[difftool "nvimdiff"]
    cmd = nvim -d \"$LOCAL\" \"$REMOTE\" -c \"wincmd w\" -c \"wincmd L\"

[interactive]
    diffFilter = delta --color-only

[rerere]
    enabled = true

[fetch]
    prune = true

[pager]
    branch = false
    diff = delta
    log = delta
    reflog = delta
    show = delta

[delta]
    navigate = true
    dark = true
    line-numbers = true
    side-by-side = false
    syntax-theme = base16

[github]
    user = Saiiru

[alias]
    s = status -sb
    st = status
    d = diff
    dc = diff --cached
    co = checkout
    sw = switch
    br = branch
    ci = commit --verbose
    cia = commit --verbose --all
    amend = commit --amend --no-edit
    lg = log --graph --decorate --oneline --abbrev-commit
    lgd = log --graph --decorate --pretty=format:'%C(yellow)%h%C(reset) %C(green)%ad%C(reset) %C(auto)%d%C(reset)%n%C(white)%B%C(reset)' --date=short
    last = log -1 --stat
    unstage = restore --staged --
    wipe-merged = !git branch --merged | grep -v '^*\\|main\\|master\\|dev$' | xargs -r git branch -d

[url "git@github.com:"]
    pushInsteadOf = https://github.com/
